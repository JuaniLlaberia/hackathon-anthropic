# ============================================
# Base de datos (Docker local)
# ============================================
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon
POSTGRES_DB=hackathon
# Esta URL la sobreescribe docker-compose para el container.
# Usala si corres el backend fuera de Docker:
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hackathon

# ============================================
# Kapso (WhatsApp Bot)
# ============================================
# Obtener de: panel de Kapso > Configuracion > Webhooks
KAPSO_WEBHOOK_SECRET=
KAPSO_API_URL=https://api.kapso.io/v1
KAPSO_API_KEY=
# Obtener de: kapso dashboard > Phone Numbers
KAPSO_PHONE_NUMBER_ID=

# ============================================
# Anthropic (Agente de publicacion)
# ============================================
# Obtener de: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ============================================
# Storage de imagenes (opcional)
# MercadoLibre OAuth
# ============================================
# Crear app en: https://developers.mercadolibre.com.ar/devcenter
ML_APP_ID=
ML_APP_SECRET=
# La redirect URI que configuraste en tu ML app (debe coincidir exactamente)
ML_REDIRECT_URI=https://<tu-ngrok>.ngrok-free.dev/api/v1/auth/ml/callback
BACKEND_BASE_URL=https://<tu-ngrok>.ngrok-free.dev

# ============================================
# Anthropic (Claude API)
# ============================================
ANTHROPIC_API_KEY=

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:8000
