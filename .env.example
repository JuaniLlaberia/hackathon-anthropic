# ============================================
# Base de datos (Docker local)
# ============================================
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon
POSTGRES_DB=hackathon
# Esta URL la sobreescribe docker-compose para el container.
# Usala si corres el backend fuera de Docker:
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hackathon

# ============================================
# Kapso (WhatsApp Bot)
# ============================================
# Obtener de: panel de Kapso > Configuracion > Webhooks
KAPSO_WEBHOOK_SECRET=
KAPSO_API_URL=https://api.kapso.io/v1
KAPSO_API_KEY=

# ============================================
# Storage de imagenes (opcional)
# ============================================
# Obtener de: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:8000
